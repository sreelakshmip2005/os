#include <stdio.h>

struct P {
    int pid, at, bt, ct, tat, wt, done;
};

int main() {
    int n, time = 0, completed = 0;
    struct P p[20];

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++) {
        p[i].pid = i+1;
        p[i].done = 0;
        printf("\nAT and BT for P%d: ",i+1);
        scanf("%d%d",&p[i].at,&p[i].bt);
    }

    while(completed < n) {
        int min = 9999, idx = -1;

        for(int i=0;i<n;i++) {
            if(p[i].at <= time && !p[i].done && p[i].bt < min) {
                min = p[i].bt;
                idx = i;
            }
        }
     if(idx != -1) {
            time += p[idx].bt;
            p[idx].ct = time;

            p[idx].tat = p[idx].ct - p[idx].at;
            p[idx].wt = p[idx].tat - p[idx].bt;

            p[idx].done = 1;
            completed++;
        } else {
            time++;
        }
    }

    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\n");
    for(int i=0;i<n;i++)
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
        p[i].pid,p[i].at,p[i].bt,p[i].ct,p[i].tat,p[i].wt);

    return 0;
}
