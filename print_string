#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>
#include <stdlib.h>

int main() {
    pid_t pid;

    pid = fork();

    if (pid < 0) {
        exit(1);
    }
    else if (pid == 0) {
        printf("PCCSL407 ");
    }
    else {
        wait(NULL);
        printf("operating systems lab");
    }

    return 0;
}

